{
  "name": "@hono-cms/example-newsroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "generate:sdk": "bun ../../packages/cli/src/index.ts schema generate --schema src/schema.ts --out src/generated/sdk.ts",
    "check:sdk": "bun ../../packages/cli/src/index.ts schema check-sdk --schema src/schema.ts --out src/generated/sdk.ts",
    "typecheck": "bun run check:sdk && tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@hono-cms/adapter-memory": "workspace:*",
    "@hono-cms/audit": "workspace:*",
    "@hono-cms/auth-tokens": "workspace:*",
    "@hono-cms/cache": "workspace:*",
    "@hono-cms/content-cache": "workspace:*",
    "@hono-cms/core": "workspace:*",
    "@hono-cms/cors": "workspace:*",
    "@hono-cms/drafts": "workspace:*",
    "@hono-cms/jobs": "workspace:*",
    "@hono-cms/jobs-runtime": "workspace:*",
    "@hono-cms/media": "workspace:*",
    "@hono-cms/openapi": "workspace:*",
    "@hono-cms/platform": "workspace:*",
    "@hono-cms/rate-limit": "workspace:*",
    "@hono-cms/schema": "workspace:*",
    "@hono-cms/storage-memory": "workspace:*",
    "@hono-cms/webhooks": "workspace:*"
  },
  "devDependencies": {
    "@types/qs": "^6.15.1",
    "vitest": "^4.0.0"
  }
}
